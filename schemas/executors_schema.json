{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "WebFramework executors",
  "type": "object",
  "description": "Executors setup",
  "patternProperties": {
    "^[A-Za-z_][A-Za-z0-9_]*$": {
      "type": "object",
      "properties": {
        "route": {
          "type": [ "string", "array" ],
          "items": { "type": "string" },
          "description": "API endpoint"
        },
        "loadType": {
          "type": "string",
          "description": "Load executor at startup or per client connection",
          "enum": [ "initialization", "dynamic" ]
        },
        "userAgentFilter": {
          "type": [ "string", "array" ],
          "items": {
            "type": "string"
          },
          "description": "Filter input requests by User-Agent"
        },
        "requireJWT": {
          "type": "boolean",
          "description": "Filter input requests by Authorization: Bearer <token>",
          "default": false
        },
        "initParameters": {
          "type": "object",
          "description": "Initialization parameters for executors that can be accessed in init function"
        },
        "api": {
          "type": "string",
          "description": "API language",
          "enum": [ "cxx", "cc", "python", "csharp" ]
        }
      },
      "required": [ "route", "loadType", "api" ]
    }
  }
}