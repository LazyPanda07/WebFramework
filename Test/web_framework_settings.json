{
  "WebServer": {
    "ip": "0.0.0.0",
    "port": "443",
    "timeout": 0
  },

  "WebFramework": {
    "settingsPaths": [
      "web.json",
      "test.json"
    ],
    "loadSources": [
      "current"
    ],
    "assetsPath": "assets",
    "templatesPath": "templates",
    "usingAssetsCache": true,
    "webServerType": "multithreaded",
    "useHTTPS": true
  },

  "Logging": {
    "usingLogging": true,
    "dateFormat": "DMY",
    "addNewLineAfterLog": true
  },

  "ThreadPoolServer": {
    "threadCount": 0
  }
}